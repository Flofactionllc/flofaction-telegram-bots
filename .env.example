# Flo Faction Telegram Bot Handler v2.0
# Copy this to .env and fill in your bot tokens
# DO NOT commit .env to version control

# Server Config
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Base URL (auto-set on Render, set manually for local dev)
# BASE_URL=https://your-app.onrender.com

# LLM Configuration
# Groq is free tier - get key at https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
# Optional: OpenAI compatible fallback
# OPENAI_API_KEY=YOUR_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4.1-nano

# Bot Tokens - 20 Flo Faction Bots
# DO NOT SHARE THESE TOKENS
CLAUDETTE_TOKEN=YOUR_TOKEN_HERE
QUANTUM_CLAW_TOKEN=YOUR_TOKEN_HERE
ZERO_CLAW_TOKEN=YOUR_TOKEN_HERE
GIGA_CLAW_TOKEN=YOUR_TOKEN_HERE
FLOFACTION_GRANT_TOKEN=YOUR_TOKEN_HERE
TERRA_CLAW_TOKEN=YOUR_TOKEN_HERE
FLOFACTION_HACKATHON_TOKEN=YOUR_TOKEN_HERE
ULTRA_CLAW_TOKEN=YOUR_TOKEN_HERE
ALPHA_CLAW_TOKEN=YOUR_TOKEN_HERE
NINJA_CLAW_TOKEN=YOUR_TOKEN_HERE
NEMO_CLAW_TOKEN=YOUR_TOKEN_HERE
DOJO_CLAW_TOKEN=YOUR_TOKEN_HERE
MEGA_CLAW_TOKEN=YOUR_TOKEN_HERE
OPEN_CLAW_TOKEN=YOUR_TOKEN_HERE
NANO_CLAW_TOKEN=YOUR_TOKEN_HERE
NANO_CLAW_IOS_TOKEN=YOUR_TOKEN_HERE
MICRO_CLAW_TOKEN=YOUR_TOKEN_HERE
OMEGA_CLAW_TOKEN=YOUR_TOKEN_HERE
TAX_CLAW_TOKEN=YOUR_TOKEN_HERE
LEX_CLAW_TOKEN=YOUR_TOKEN_HERE
